// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Event {
  id              String   @id @default(cuid())
  slug            String   @unique
  coupleName      String
  date            DateTime
  coverImageUrl   String?
  moderatorPin    String   // Default "1234" diatur di service/controller saat pertama kali
  couplePassword  String   // Default "password" diatur di service/controller
  missionsJson    Json
  theme           String   @default("rose") // rose, sage, ocean, lavender, gold
  createdAt       DateTime @default(now())
  photos          Photo[]
  guestbookEntries GuestbookEntry[]
}

model GuestbookEntry {
  id              String   @id @default(cuid())
  eventId         String
  name            String
  message         String?
  attendanceCount Int      @default(1)
  souvenirClaimed Boolean  @default(false)
  createdAt       DateTime @default(now())
  
  event           Event    @relation(fields: [eventId], references: [id])
}

model Photo {
  id               String      @id @default(cuid())
  eventId          String
  uploaderSessionId String
  storageKey       String
  thumbnailKey     String?
  caption          String?
  missionId        String?
  status           PhotoStatus @default(PENDING)
  createdAt        DateTime    @default(now())
  event            Event       @relation(fields: [eventId], references: [id])
}

enum PhotoStatus {
  PENDING
  APPROVED
  REJECTED
}
